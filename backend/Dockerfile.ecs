# Dockerfile.ecs — Optimized for AWS ECS Fargate deployment
# Supports AWS Bedrock (Claude + Cohere v3) with IAM Task Role
# Works with Docker Hub images directly (no ECR required)
#
# Usage: Build from PROJECT ROOT
#   docker build -f backend/Dockerfile.ecs -t mynameismo/rag-backend-render:latest .
#   docker push mynameismo/rag-backend-render:latest
#
# ECS Deployment:
#   - Uses IAM Task Role for Bedrock access (no credentials needed)
#   - Mount EFS at /app/data for persistent ChromaDB storage
#   - Or use baked data with startup script (copies to ephemeral storage if needed)

FROM python:3.12-slim

# System deps (build-essential needed for chroma-hnswlib)
RUN apt-get update && apt-get install -y \
    build-essential \
    curl \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# ── Python dependencies (cached layer) ──────────────────────────────────────
COPY backend/requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# ── Application code ─────────────────────────────────────────────────────────
COPY backend/app/ ./app/

# ── Bake data into image (stored separately from runtime mount) ──────────────
# EFS mounts at /app/data, so we store baked data at /app/data_baked
# and copy it to /app/data at startup if the directory is empty
RUN mkdir -p /app/data_baked/chroma_db /app/data_baked/documents
COPY data/chroma_db/ /app/data_baked/chroma_db/
COPY data/documents/ /app/data_baked/documents/

# ── Startup script ───────────────────────────────────────────────────────────
# Copies baked data to runtime directory if empty (handles EFS mounts)
COPY backend/start.sh /app/start.sh
RUN chmod +x /app/start.sh

# Create runtime data directories
RUN mkdir -p /app/data/chroma_db /app/data/documents

# ── Runtime ───────────────────────────────────────────────────────────────────
ENV PORT=8000
EXPOSE ${PORT}

HEALTHCHECK --interval=30s --timeout=10s --start-period=60s --retries=3 \
    CMD curl -f http://localhost:${PORT}/health || exit 1

# Use startup script to handle data initialization
CMD ["/app/start.sh"]
