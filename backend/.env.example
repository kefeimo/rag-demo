# LLM Configuration
LLM_PROVIDER=openai  # Options: gpt4all, openai (UPDATED: Switched to GPT-3.5 for better quality)
OPENAI_MODEL=gpt-3.5-turbo  # GPT-3.5-turbo for production-grade answers
GPT4ALL_MODEL=mistral-7b-instruct-v0.1.Q4_0.gguf  # Kept for reference
OPENAI_API_KEY=your_openai_api_key_here  # Optional, for OpenAI provider

# Embedding Configuration
EMBEDDING_PROVIDER=openai  # Options: openai, sentence-transformers
OPENAI_EMBEDDING_MODEL=text-embedding-3-small  # Used when EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2  # Used when EMBEDDING_PROVIDER=sentence-transformers

# ChromaDB Configuration
CHROMA_PERSIST_DIRECTORY=./data/chroma_db
# CHROMA_COLLECTION_NAME — server-side query fallback only.
#
# Collection routing works as follows:
#   • Ingestion is hardcoded (independent of this value):
#       /api/v1/ingest           → always writes to 'fastapi_docs'
#       /api/v1/ingest/visa-docs → always writes to 'vcc_docs'
#   • Queries: frontend toggle sends 'collection' field per-request,
#     so this env var is only used when no 'collection' is passed
#     (e.g. evaluation scripts, direct curl calls).
#   • On fresh start, auto-ingest populates both collections.
#     Deleting data/chroma_db and restarting rebuilds both from scratch.
#
# Valid values: fastapi_docs | vcc_docs
CHROMA_COLLECTION_NAME=vcc_docs

# RAG Configuration
CHUNK_SIZE=500
CHUNK_OVERLAP=50
TOP_K_RESULTS=5
CONFIDENCE_THRESHOLD=0.65

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

# CORS Configuration
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Logging
LOG_LEVEL=INFO

# Evaluation
RAGAS_METRICS=context_precision,faithfulness,answer_relevancy
