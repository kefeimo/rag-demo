# LLM Configuration - Using AWS Bedrock Claude
LLM_PROVIDER=bedrock  # Options: gpt4all, openai, bedrock
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-20250514-v1:0  # Bedrock LLM model ID

# AWS Bedrock Configuration (for LLM only)
# Option 1: Use AWS Profile (recommended for SSO)
AWS_PROFILE=AssetScore  # Your SSO profile name from ~/.aws/credentials
AWS_REGION=us-west-2  # AWS Region for Bedrock

# Option 2: Use static credentials (comment out if using AWS_PROFILE)
# AWS_ACCESS_KEY_ID=your_aws_access_key_id
# AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key

# Embedding Configuration - Using OpenAI (best quality and speed)
EMBEDDING_PROVIDER=openai  # Options: openai, sentence-transformers, bedrock
OPENAI_EMBEDDING_MODEL=text-embedding-3-large  # or text-embedding-3-small (faster, cheaper)
OPENAI_API_KEY=your_openai_api_key_here  # Required for embeddings

# Alternative LLM/Embedding providers (not used by default)
OPENAI_MODEL=gpt-3.5-turbo  # Used when LLM_PROVIDER=openai
GPT4ALL_MODEL=mistral-7b-instruct-v0.1.Q4_0.gguf  # Used when LLM_PROVIDER=gpt4all
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2  # Used when EMBEDDING_PROVIDER=sentence-transformers
BEDROCK_EMBEDDING_MODEL=cohere.embed-english-v3  # Used when EMBEDDING_PROVIDER=bedrock

# ChromaDB Configuration
CHROMA_PERSIST_DIRECTORY=./data/chroma_db
# CHROMA_COLLECTION_NAME — server-side query fallback only.
#
# Collection routing works as follows:
#   • Ingestion: /api/v1/ingest → always writes to 'fastapi_docs'
#   • Queries: frontend sends 'collection' field per-request,
#     so this env var is only used when no 'collection' is passed
#     (e.g. evaluation scripts, direct curl calls).
#   • On fresh start, auto-ingest populates the fastapi_docs collection.
#     Deleting data/chroma_db and restarting rebuilds from scratch.
#
# Valid values: fastapi_docs
CHROMA_COLLECTION_NAME=fastapi_docs

# RAG Configuration
CHUNK_SIZE=500
CHUNK_OVERLAP=50
TOP_K_RESULTS=5
RELEVANCE_THRESHOLD=0.65

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

# CORS Configuration
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Logging
LOG_LEVEL=INFO

# Evaluation
RAGAS_METRICS=context_precision,faithfulness,answer_relevancy
